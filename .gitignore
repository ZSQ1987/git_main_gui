# ===================== Python 项目通用忽略 =====================
# Python 编译生成的字节码文件（核心！必忽略）
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===================== 操作系统/编辑器通用忽略 =====================
# Windows 临时文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN
*.tmp
*.temp
*.ps1
*.zip

# 日志文件（如果你的GUI有日志输出）
*.log
logs/
*.ico

# IDE/编辑器配置（比如VSCode/PyCharm）
.idea/
.vscode/
*.swp
*.swo
.DS_Store  # Mac系统文件

# ===================== 你的 Git GUI 工具专属忽略（可选） =====================
# 比如GUI生成的配置文件（如果不想上传）
config.ini  # 若有本地配置，可忽略
cache/      # 若有缓存目录，可忽略